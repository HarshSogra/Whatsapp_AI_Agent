generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DIRECT_URL")
  directUrl = env("DIRECT_URL")
}

model Institute {
  id                    String    @id @default(uuid())
  name                  String
  industry              String?
  timezone              String    @default("Asia/Kolkata")
  aiSystemPrompt        String?
  whatsappPhoneNumberId String?   @unique
  whatsappDisplayNumber String?
  adminPhoneNumber      String?
  contactPhoneNumber    String?   // The direct phone number for student calls/enquiries
  address               String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  courses               Course[]
  faculty               Faculty[]
  students              Student[]
  users                 User[]

  @@index([whatsappPhoneNumberId])
}

model User {
  id           String    @id @default(uuid())
  instituteId  String
  email        String    @unique
  passwordHash String
  role         String    @default("ADMIN")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  institute    Institute @relation(fields: [instituteId], references: [id])
}

model Course {
  id          String        @id @default(uuid())
  instituteId String
  name        String
  description String?
  fees        Float
  duration    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  institute   Institute     @relation(fields: [instituteId], references: [id])
  bookings    DemoBooking[]
}

model Student {
  id                    String        @id @default(uuid())
  instituteId           String
  phone                 String
  name                  String?
  status                String        @default("COLD") // Original status field
  leadStatus           String        @default("COLD") // HOT, WARM, COLD conversion tracking
  lastHighIntentAt       DateTime?     
  lastFollowUpSentAt     DateTime?     
  followUpCount         Int           @default(0) 
  lastFollowUpType      String?       // "FIRST" or "SECOND"
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  bookings              DemoBooking[]
  messages              Message[]
  institute             Institute     @relation(fields: [instituteId], references: [id])

  @@unique([instituteId, phone])
}

model Message {
  id          String   @id @default(uuid())
  studentId   String
  whatsappMessageId String? @unique
  phoneNumber String
  role        String   // "user" or "assistant"
  content     String
  intent      String?  // "HIGH" or "LOW"
  timestamp   DateTime @default(now())
  student     Student  @relation(fields: [studentId], references: [id])
}

model DemoBooking {
  id          String   @id @default(uuid())
  studentId   String
  courseId    String
  scheduledAt DateTime
  status      String   @default("SCHEDULED")
  createdAt   DateTime @default(now())
  course      Course   @relation(fields: [courseId], references: [id])
  student     Student  @relation(fields: [studentId], references: [id])
}
model Faculty {
  id            String    @id @default(uuid())
  instituteId   String
  name          String
  subject       String
  experience    String?
  qualification String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  institute     Institute @relation(fields: [instituteId], references: [id])
}
